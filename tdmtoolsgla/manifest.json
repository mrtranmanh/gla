{
    "name": "TDM tools Gladiatus",
    "description": "TDM tools Gladiatus Chrome Extension",
    "version": "1.0",
    "action": {
        "default_icon": "icon.png",
        "default_popup": "popup.html"
    },
    "permissions": [
        "alarms",
        "storage",
        "tabs",
        "webNavigation",
        "webRequest"
    ],
    "host_permissions": [
        "https://*.gladiatus.gameforge.com/*",
        "https://*.gladiatus-tools.com/*"
    ],
    "manifest_version": 3,
    "background": {
        "service_worker": "background.js",
        "type": "module"
    },
    "content_scripts": [
        {
            "all_frames": true,
            "css": [
                "css/styles.css"
            ],
            "exclude_matches": [
                "*://*.gladiatus.gameforge.com/game/index.php?mod=start"
            ],
            "js": [
                "js/vendor/jquery.min.js",
                "js/dungeon.js",
                "js/base.js",
                "js/gca_features.js",
                "js/reloadpage.js",
                "js/trainning.js",
                "js/circusProvinciarum.js",
                "js/heal.js",
                "js/auction.js",
                "js/searchitem.js",
                "js/shop.js",
                "js/forge-equipment-stats.js"
            ],
            "matches": [
                "https://*.gladiatus.gameforge.com/*"
            ],
            "run_at": "document_idle"
        }
    ],
    "web_accessible_resources": [
        {
            "resources": [
                "assets/*.svg",
                "assets/*.png",
                "assets/*.jpg",
                "assets/*.jpeg",
                "assets/*.gif"
            ],
            "matches": [
                "https://*.gladiatus.gameforge.com/*"
            ]
        }
    ]
}
